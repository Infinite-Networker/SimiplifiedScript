# Interactive REPL session example
# Run `python interpreter.py` with no arguments to enter the REPL.
#
# Example session:
#
#   SimplifiedScript REPL v1.0.0
#   Type 'exit()' or press Ctrl+C to quit.
#
#   >>> let name = "SimplifiedScript";
#   >>> print("Hello, " + name);
#   Hello, SimplifiedScript
#   >>> exit()

let name = "SimplifiedScript";
print("Hello, " + name);
